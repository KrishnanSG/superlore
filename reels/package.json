{
  "name": "superlore-reels",
  "private": true,
  "type": "module",
  "description": "Remotion compositions for superlore release reels — programmatic, on-brand, re-renderable. Standalone (NOT a pnpm-workspace member) so its heavy deps never bloat the docs deploy or CI.",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render": "remotion render src/index.ts Release012 ../apps/docs/public/releases/0.12.mp4 --codec=h264",
    "poster": "remotion still src/index.ts Release012 ../apps/docs/public/releases/0.12.png --frame=430"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.484",
    "@remotion/cli": "4.0.484",
    "@remotion/renderer": "4.0.484",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.484"
  },
  "devDependencies": {
    "@types/react": "^19.0.0"
  }
}
