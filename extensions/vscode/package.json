{
  "name": "superlore-preview",
  "displayName": "superlore Preview",
  "version": "0.4.6",
  "description": "Live, dual-representation preview for superlore .mdx — renders every component (Canvas/whiteboard, Timeline, Board, Table, …) as you type, with FigJam-style comment pins and Copy to Agent.",
  "license": "Apache-2.0",
  "author": "Krishnan S G",
  "private": true,
  "publisher": "superlore",
  "icon": "media/icon.png",
  "homepage": "https://superlore.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrishnanSG/superlore.git",
    "directory": "extensions/vscode"
  },
  "bugs": "https://github.com/KrishnanSG/superlore/issues",
  "qna": "https://github.com/KrishnanSG/superlore/issues",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Visualization",
    "Notebooks",
    "Other"
  ],
  "keywords": [
    "superlore",
    "mdx",
    "preview",
    "whiteboard",
    "canvas",
    "knowledge base",
    "mcp",
    "agent"
  ],
  "galleryBanner": {
    "color": "#0B0C0E",
    "theme": "dark"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:mdx",
    "onLanguage:markdown",
    "onView:superlore.corpus",
    "onView:superlore.page",
    "workspaceContains:superlore.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "superlore",
          "title": "superlore",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "superlore": [
        {
          "id": "superlore.corpus",
          "name": "Corpus",
          "icon": "media/activity-icon.svg"
        },
        {
          "id": "superlore.page",
          "name": "This page",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "superlore.corpus",
        "contents": "No superlore knowledge base found in this workspace.\n\nsuperlore looks for a `superlore.json` at the workspace root, then a couple of levels down (so it finds a KB inside a monorepo). If yours lives somewhere else, point at it with the `superlore.root` setting.\n\n[Scaffold a KB](command:superlore.scaffoldHint)\n\n[Set the KB location](command:workbench.action.openSettings?%22superlore.root%22)\n\n[Open the docs](https://superlore.vercel.app/docs)"
      }
    ],
    "configuration": {
      "title": "superlore",
      "properties": {
        "superlore.root": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to your superlore KB (the folder containing `superlore.json`), absolute or relative to the first workspace folder. Leave empty to auto-detect — superlore checks the workspace root, then a couple of levels down for a monorepo."
        }
      }
    },
    "commands": [
      {
        "command": "superlore.openPreview",
        "title": "Open Preview",
        "category": "superlore",
        "icon": {
          "light": "media/icon.svg",
          "dark": "media/icon.svg"
        }
      },
      {
        "command": "superlore.refreshCorpus",
        "title": "Refresh",
        "category": "superlore",
        "icon": "$(refresh)"
      },
      {
        "command": "superlore.scaffoldHint",
        "title": "Scaffold a Knowledge Base",
        "category": "superlore"
      },
      {
        "command": "superlore.openSource",
        "title": "Open Source (.mdx)",
        "category": "superlore",
        "icon": "$(go-to-file)"
      }
    ],
    "keybindings": [
      {
        "command": "superlore.openPreview",
        "key": "ctrl+k s",
        "mac": "cmd+k s",
        "when": "editorTextFocus && (editorLangId == mdx || resourceExtname == .mdx || resourceExtname == .superlore || resourceFilename =~ /\\.superlore\\.mdx$/)"
      },
      {
        "command": "superlore.openPreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorTextFocus && (editorLangId == mdx || resourceExtname == .mdx || resourceExtname == .superlore || resourceFilename =~ /\\.superlore\\.mdx$/)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "superlore.openPreview",
          "when": "resourceExtname == .mdx || resourceExtname == .superlore || resourceFilename =~ /\\.superlore\\.mdx$/",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "superlore.openPreview",
          "when": "resourceExtname == .mdx || resourceExtname == .superlore || resourceFilename =~ /\\.superlore\\.mdx$/ || editorLangId == mdx"
        }
      ],
      "view/title": [
        {
          "command": "superlore.refreshCorpus",
          "when": "view == superlore.corpus",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "superlore.openSource",
          "when": "view == superlore.corpus && viewItem == superlorePage",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "pnpm run build:webview && pnpm run build:extension",
    "build:webview": "node scripts/sync-superlore-src.mjs && vite build",
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p webview/tsconfig.json",
    "watch:extension": "esbuild src/extension.ts --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.cjs --watch",
    "package": "pnpm run build && npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@fontsource/caveat": "^5.2.5",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@mdx-js/mdx": "^3.1.1",
    "@shikijs/engine-javascript": "^4.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.7.0",
    "esbuild": "^0.25.0",
    "fumadocs-core": "16.8.2",
    "fumadocs-ui": "16.8.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "superlore": "workspace:*",
    "tailwindcss": "^4.2.2",
    "typescript": "6.0.3",
    "vite": "^6.0.0"
  }
}
