# Source — only the built output ships in the .vsix.
.vscode/**
src/**
webview/**
node_modules/**
vite.config.ts
tsconfig.json
**/tsconfig.json
**/*.map
.gitignore
verify/**
scratch/**
scripts/**
# The icon source SVG — only the rendered media/icon.png ships.
media/icon.svg

# Keep: dist/** (extension.js + webview/), media/icon.png, README.md, package.json, LICENSE
!dist/**
!media/icon.png
!README.md
!package.json
