# Source — only the built output ships in the .vsix.
.vscode/**
src/**
webview/**
node_modules/**
vite.config.ts
tsconfig.json
**/tsconfig.json
**/*.map
.gitignore
verify/**
scratch/**
scripts/**

# Keep: dist/** (extension.cjs + webview/), media/** (icon.png marketplace icon + the Fold-mark
# SVGs the editor-title command and the Activity Bar reference), README, manifest.
!dist/**
!media/**
!README.md
!package.json
