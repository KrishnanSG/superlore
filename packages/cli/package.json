{
  "name": "superlore-cli",
  "version": "0.7.6",
  "description": "The superlore CLI — scaffold, run, and build an agent-native knowledge base. One corpus. Humans and agents.",
  "license": "Apache-2.0",
  "author": "Krishnan S G",
  "homepage": "https://github.com/KrishnanSG/superlore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrishnanSG/superlore.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/KrishnanSG/superlore/issues",
  "keywords": [
    "superlore",
    "cli",
    "knowledge-base",
    "mdx",
    "fumadocs",
    "mcp",
    "agent",
    "scaffold"
  ],
  "type": "module",
  "bin": {
    "superlore": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "cac": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
