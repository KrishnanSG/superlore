{
  "name": "superlore",
  "version": "0.12.0",
  "description": "The agent-native knowledge base — dual-representation components, theme, MCP, and auth. One corpus. Humans and agents.",
  "license": "Apache-2.0",
  "author": "Krishnan S G",
  "homepage": "https://github.com/KrishnanSG/superlore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrishnanSG/superlore.git",
    "directory": "packages/superlore"
  },
  "bugs": "https://github.com/KrishnanSG/superlore/issues",
  "keywords": [
    "superlore",
    "knowledge-base",
    "mdx",
    "fumadocs",
    "mcp",
    "agent",
    "nextjs",
    "docs"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./mcp": {
      "types": "./src/mcp/index.ts",
      "import": "./src/mcp/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./frontmatter": {
      "types": "./src/knowledge/frontmatter.ts",
      "import": "./src/knowledge/frontmatter.ts"
    },
    "./mdx": {
      "types": "./src/mdx.ts",
      "import": "./src/mdx.ts"
    },
    "./mdx-lint": {
      "types": "./src/mdx-lint.ts",
      "import": "./src/mdx-lint.ts"
    },
    "./search": {
      "types": "./src/search.ts",
      "import": "./src/search.ts"
    },
    "./ui": {
      "types": "./src/ui.tsx",
      "import": "./src/ui.tsx"
    },
    "./runtime": {
      "types": "./src/runtime.tsx",
      "import": "./src/runtime.tsx"
    },
    "./source": {
      "types": "./src/source.ts",
      "import": "./src/source.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    },
    "./next": {
      "types": "./src/next.ts",
      "import": "./src/next.ts"
    },
    "./css": "./src/theme/superlore.css",
    "./runtime.css": "./dist/css/superlore-runtime.css"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./mcp": {
        "types": "./dist/mcp.d.mts",
        "import": "./dist/mcp.mjs"
      },
      "./auth": {
        "types": "./dist/auth.d.mts",
        "import": "./dist/auth.mjs"
      },
      "./frontmatter": {
        "types": "./dist/frontmatter.d.mts",
        "import": "./dist/frontmatter.mjs"
      },
      "./mdx": {
        "types": "./dist/mdx.d.mts",
        "import": "./dist/mdx.mjs"
      },
      "./mdx-lint": {
        "types": "./dist/mdx-lint.d.mts",
        "import": "./dist/mdx-lint.mjs"
      },
      "./search": {
        "types": "./dist/search.d.mts",
        "import": "./dist/search.mjs"
      },
      "./ui": {
        "types": "./dist/ui.d.mts",
        "import": "./dist/ui.mjs"
      },
      "./runtime": {
        "types": "./dist/runtime.d.mts",
        "import": "./dist/runtime.mjs"
      },
      "./source": {
        "types": "./dist/source.d.mts",
        "import": "./dist/source.mjs"
      },
      "./config": {
        "types": "./dist/config.d.mts",
        "import": "./dist/config.mjs"
      },
      "./next": {
        "types": "./dist/next.d.mts",
        "import": "./dist/next.mjs"
      },
      "./css": "./dist/css/superlore.css",
      "./runtime.css": "./dist/css/superlore-runtime.css"
    }
  },
  "scripts": {
    "build": "tsdown && node scripts/build-css.mjs",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@shikijs/engine-javascript": "^4.2.0",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "lucide-react": "^1.21.0",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "roughjs": "^4.6.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "fumadocs-core": "^16",
    "fumadocs-mdx": "^14",
    "fumadocs-ui": "^16",
    "next": "^16",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.2"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "fumadocs-mdx": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "next-auth": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/cli": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "fumadocs-core": "16.8.2",
    "fumadocs-mdx": "^14.3.2",
    "fumadocs-ui": "16.8.2",
    "jsdom": "^29.1.1",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "postcss-selector-parser": "^7.1.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.3",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
