{
  "name": "superlore",
  "version": "0.2.0",
  "description": "The agent-native knowledge base — dual-representation components, theme, MCP, and auth. One corpus. Humans and agents.",
  "license": "Apache-2.0",
  "author": "Krishnan S G",
  "homepage": "https://github.com/KrishnanSG/superlore#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KrishnanSG/superlore.git",
    "directory": "packages/superlore"
  },
  "bugs": "https://github.com/KrishnanSG/superlore/issues",
  "keywords": [
    "superlore",
    "knowledge-base",
    "mdx",
    "fumadocs",
    "mcp",
    "agent",
    "nextjs",
    "docs"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./mcp": {
      "types": "./src/mcp/index.ts",
      "import": "./src/mcp/index.ts"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./src/auth/index.ts"
    },
    "./frontmatter": {
      "types": "./src/knowledge/frontmatter.ts",
      "import": "./src/knowledge/frontmatter.ts"
    },
    "./ui": {
      "types": "./src/ui.tsx",
      "import": "./src/ui.tsx"
    },
    "./source": {
      "types": "./src/source.ts",
      "import": "./src/source.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts"
    },
    "./next": {
      "types": "./src/next.ts",
      "import": "./src/next.ts"
    },
    "./css": "./src/theme/superlore.css"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./mcp": {
        "types": "./dist/mcp.d.ts",
        "import": "./dist/mcp.js"
      },
      "./auth": {
        "types": "./dist/auth.d.ts",
        "import": "./dist/auth.js"
      },
      "./frontmatter": {
        "types": "./dist/frontmatter.d.ts",
        "import": "./dist/frontmatter.js"
      },
      "./ui": {
        "types": "./dist/ui.d.ts",
        "import": "./dist/ui.js"
      },
      "./source": {
        "types": "./dist/source.d.ts",
        "import": "./dist/source.js"
      },
      "./config": {
        "types": "./dist/config.d.ts",
        "import": "./dist/config.js"
      },
      "./next": {
        "types": "./dist/next.d.ts",
        "import": "./dist/next.js"
      },
      "./css": "./dist/css/superlore.css"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "elkjs": "^0.11.1",
    "lucide-react": "^1.21.0",
    "roughjs": "^4.6.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1",
    "fumadocs-core": "^16",
    "fumadocs-ui": "^16",
    "fumadocs-mdx": "^14",
    "mermaid": "^11",
    "next": "^16",
    "next-auth": "^5",
    "next-themes": "^0.4",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.2"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "fumadocs-mdx": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "next-auth": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild-plugin-preserve-directives": "^0.0.11",
    "fumadocs-core": "16.8.2",
    "fumadocs-ui": "16.8.2",
    "fumadocs-mdx": "^14.3.1",
    "jsdom": "^29.1.1",
    "mermaid": "^11.15.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  }
}
